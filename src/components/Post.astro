---
const { url, title, description, image } = Astro.props;
---
<div data-usal="fade duration-400" class="postContainer">
    <img 
        src={image.url} 
        width="480" 
        height="270" 
        alt={image.alt} />

    <div class="postInfoContainer">
        <b><a href={url}>{title}</a></b>
        <p>{description}</p>
    </div>
</div>

<style>
    .postContainer {
        display: flex;
        padding: 1rem 0;
    }

    .postInfoContainer a {
        font-size: 1.5rem;
        color: var(--accent);
    }

    .postInfoContainer p {
        color: var(--foreground);
    }

    .postInfoContainer {
        padding: 0 2rem;
    }
</style>
